# Copy this to .env and fill in your values
# Never commit .env to git

# GitHub Personal Access Token (classic, public_repo scope)
# Get one at: https://github.com/settings/tokens
GITHUB_TOKEN=ghp_your_token_here

# Local Postgres / Airflow metadata database
AIRFLOW_DB_USER=airflow
AIRFLOW_DB_PASSWORD=airflow
AIRFLOW_DB_NAME=airflow

# Local warehouse database
WAREHOUSE_DB_USER=warehouse
WAREHOUSE_DB_PASSWORD=warehouse
WAREHOUSE_DB_NAME=github_warehouse

# Local Airflow UI admin account
AIRFLOW_ADMIN_USERNAME=admin
AIRFLOW_ADMIN_PASSWORD=admin
AIRFLOW_ADMIN_EMAIL=admin@example.com

# Airflow UID (run: echo $(id -u) to get yours)
AIRFLOW_UID=50000
